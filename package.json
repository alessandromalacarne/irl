{
  "name": "irl",
  "version": "0.2.0",
  "bin": {
    "irl": "bin/irl.js"
  },
  "scripts": {
    "dev": "npm --prefix web run dev",
    "build": "npm run build --prefix infra && npm install --prefix web && npm run build --prefix web",
    "prod": "npm run deploy --prefix infra && node scripts/write-env.mjs && npm run dev --prefix web",
    "watch": "tsc -w",
    "test": "vitest run && npm run test --prefix web",
    "cdk": "cdk",
    "release": "standard-version",
    "release:minor": "standard-version --release-as minor",
    "release:major": "standard-version --release-as major",
    "prepare": "husky"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.4.3",
    "@commitlint/config-conventional": "^20.4.3",
    "@types/node": "22.7.9",
    "@vitest/coverage-v8": "^4.0.18",
    "happy-dom": "^20.8.3",
    "husky": "^9.1.7",
    "standard-version": "^9.5.0",
    "ts-node": "^10.9.2",
    "typescript": "~5.6.3",
    "vitest": "^4.0.18"
  },
  "dependencies": {
    "aws-cdk-lib": "^2.236.0",
    "constructs": "^10.4.5"
  }
}
